<?xml version='1.0' encoding='UTF-8'?>
<module fritzingVersion="0.5.2b.02.18.4756" moduleId="adafruit_4ebb890bd6700a22ab9a6050634b911b_4_1D" referenceFile="Adafruit PiRTC PCF8523.fzp">
 <version>4</version>
 <date>2017-02-01</date>
 <author>ladyada</author>
 <description>&lt;!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0//EN" "http://www.w3.org/TR/REC-html40/strict.dtd">
&lt;html>&lt;head>&lt;meta name="qrichtext" content="1" />&lt;style type="text/css">
p, li { white-space: pre-wrap; }
&lt;/style>&lt;/head>&lt;body style=" font-family:'MS Shell Dlg 2'; font-size:8.25pt; font-weight:400; font-style:normal;">
&lt;p style=" margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">This is a great battery-backed real time clock (RTC) that allows your Raspberry Pi project to keep track of time if the power is lost. Perfect for data-logging, clock-building, time-stamping, timers and alarms, etc. Equipped with &lt;span style=" font-weight:600;">PCF8523&lt;/span> RTC, it works great with the Raspberry Pi and has native kernel support.&lt;/p>
&lt;p style=" margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">Works perfectly with any &lt;a href="https://learn.adafruit.com/adding-a-real-time-clock-to-raspberry-pi">&lt;span style=" text-decoration: underline; color:#0000ff;">Raspberry Pi (or similar single board linux computer)&lt;/span>&lt;/a> including the Pi 1, Pi 2, Pi 3, Pi Zero, A+, B+ etc.&lt;/p>
&lt;ul style="margin-top: 0px; margin-bottom: 0px; margin-left: 0px; margin-right: 0px; -qt-list-indent: 1;">&lt;li style=" margin-top:12px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">Fully assembled &amp;amp; tested PCB plugs directly into your Pi's GPIO pins - &lt;span style=" font-weight:600;">No soldering required!&lt;/span>&lt;/li>
&lt;li style=" margin-top:0px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">Will keep time for 5 years or more&lt;/li>&lt;/ul>&lt;/body>&lt;/html></description>
 <title>Adafruit PiRTC PCF8523</title>
