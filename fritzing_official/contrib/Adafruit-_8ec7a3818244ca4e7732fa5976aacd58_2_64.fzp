  <connector id="connector33" name="CB1" type="male">
   <description>CB1</description>
   <views>
    <breadboardView>
     <p layer="breadboard" svgId="connector33pin"/>
    </breadboardView>
    <schematicView>
     <p layer="schematic" terminalId="connector33terminal" svgId="connector33pin"/>
    </schematicView>
