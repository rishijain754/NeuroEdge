  <connector type="female" name="IO2" id="connector8">
   <description>IO2</description>
   <views>
    <breadboardView>
     <p layer="breadboard" svgId="connector8pin"/>
    </breadboardView>
    <schematicView>
     <p terminalId="connector8terminal" layer="schematic" svgId="connector8pin"/>
