   <layers image="breadboard/Adafruit-_51c7bfe311c61ef0336338d798cc4f22_1_44_breadboard.svg">
    <layer layerId="breadboard"/>
   </layers>
  </breadboardView>
  <schematicView>
   <layers image="schematic/Adafruit-_51c7bfe311c61ef0336338d798cc4f22_1_44_schematic.svg">
    <layer layerId="schematic"/>
   </layers>
  </schematicView>
  <pcbView>
   <layers image="pcb/Adafruit-_51c7bfe311c61ef0336338d798cc4f22_1_44_pcb.svg">
    <layer layerId="copper1"/>
    <layer layerId="silkscreen"/>
    <layer layerId="copper0"/>
   </layers>
  </pcbView>
  <iconView>
   <layers image="icon/Adafruit-_51c7bfe311c61ef0336338d798cc4f22_1_44_icon.svg">
    <layer layerId="icon"/>
   </layers>
  </iconView>
 </views>
 <connectors>
  <connector name="VBUS" id="connector52" type="male">
   <description>VBUS</description>
   <views>
    <breadboardView>
     <p layer="breadboard" svgId="connector52pin"/>
    </breadboardView>
    <schematicView>
     <p layer="schematic" terminalId="connector52terminal" svgId="connector52pin"/>
    </schematicView>
    <pcbView>
     <p layer="copper0" svgId="connector52pad"/>
     <p layer="copper1" svgId="connector52pad"/>
    </pcbView>
   </views>
  </connector>
  <connector name="VBUS" id="connector68" type="female">
   <description>VBUS</description>
   <views>
