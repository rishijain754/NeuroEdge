  <connector name="D13" id="connector105" type="male">
   <description>D13</description>
   <views>
    <breadboardView>
     <p layer="breadboard" svgId="connector105pin"/>
    </breadboardView>
    <schematicView>
     <p layer="schematic" terminalId="connector105terminal" svgId="connector105pin"/>
    </schematicView>
    <pcbView>
