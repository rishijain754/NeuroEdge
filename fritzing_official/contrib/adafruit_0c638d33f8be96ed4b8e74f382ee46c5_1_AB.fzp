<?xml version='1.0' encoding='UTF-8'?>
<module fritzingVersion="0.5.2b.02.18.4756" referenceFile="JST2.fzp" moduleId="adafruit_0c638d33f8be96ed4b8e74f382ee46c5_1_AB">
 <version>4</version>
 <date>2016-10-22</date>
 <author>andydoro</author>
 <description>&lt;!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0//EN" "http://www.w3.org/TR/REC-html40/strict.dtd">
&lt;html>&lt;head>&lt;meta name="qrichtext" content="1" />&lt;style type="text/css">
p, li { white-space: pre-wrap; }
&lt;/style>&lt;/head>&lt;body style=" font-family:'.Helvetica Neue DeskInterface'; font-size:13pt; font-weight:400; font-style:normal;">
&lt;p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">A simple 2-pin connector soldered onto a breadboard-friendly breakout. This is compatible with the &amp;quot;JST PH 2-pin&amp;quot; connector. Mates perfectly with all our 1-cell LiPoly and LiIon batteries as well as our 6V coin cell holder and 3xAAA battery pack. We also have simple JST pigtails that mate with this connector.&lt;/p>&lt;/body>&lt;/html></description>
 <title>Adafruit JST breakout</title>
 <tags/>
 <properties>
  <property name="family">Adafruit JST breakout</property>
  <property name="variant">variant 1</property>
  <property name="part number">Adafruit #1862</property>
 </properties>
 <views>
  <breadboardView>
   <layers image="breadboard/adafruit_209e9f37f4a4706aa07cca5ace98eb7c_2_breadboard_AB.svg">
    <layer layerId="breadboard"/>
   </layers>
  </breadboardView>
  <schematicView>
   <layers image="schematic/adafruit_209e9f37f4a4706aa07cca5ace98eb7c_2_schematic_AB.svg">
    <layer layerId="schematic"/>
   </layers>
  </schematicView>
  <pcbView>
   <layers image="pcb/adafruit_209e9f37f4a4706aa07cca5ace98eb7c_2_pcb_AB.svg">
    <layer layerId="copper1"/>
    <layer layerId="silkscreen"/>
    <layer layerId="copper0"/>
   </layers>
  </pcbView>
  <iconView>
   <layers image="icon/adafruit_209e9f37f4a4706aa07cca5ace98eb7c_2_icon_AB.svg">
    <layer layerId="icon"/>
   </layers>
  </iconView>
 </views>
 <connectors>
  <connector id="connector1" name="V-" type="male">
   <description>V-</description>
   <views>
    <breadboardView>
     <p layer="breadboard" svgId="connector1pin"/>
    </breadboardView>
    <schematicView>
     <p layer="schematic" terminalId="connector1terminal" svgId="connector1pin"/>
    </schematicView>
    <pcbView>
     <p layer="copper0" svgId="connector1pad"/>
     <p layer="copper1" svgId="connector1pad"/>
    </pcbView>
   </views>
  </connector>
  <connector id="connector2" name="V-" type="male">
   <description>V-</description>
   <views>
    <breadboardView>
     <p layer="breadboard" svgId="connector2pin"/>
    </breadboardView>
    <schematicView>
     <p layer="schematic" terminalId="connector2terminal" svgId="connector2pin"/>
    </schematicView>
    <pcbView>
     <p layer="copper0" svgId="connector2pad"/>
     <p layer="copper1" svgId="connector2pad"/>
    </pcbView>
   </views>
  </connector>
  <connector id="connector3" name="V+" type="male">
   <description>V+</description>
   <views>
    <breadboardView>
     <p layer="breadboard" svgId="connector3pin"/>
    </breadboardView>
    <schematicView>
     <p layer="schematic" terminalId="connector3terminal" svgId="connector3pin"/>
    </schematicView>
    <pcbView>
     <p layer="copper0" svgId="connector3pad"/>
     <p layer="copper1" svgId="connector3pad"/>
    </pcbView>
   </views>
  </connector>
  <connector id="connector4" name="V+" type="male">
   <description>V+</description>
   <views>
    <breadboardView>
     <p layer="breadboard" svgId="connector4pin"/>
    </breadboardView>
    <schematicView>
     <p layer="schematic" terminalId="connector4terminal" svgId="connector4pin"/>
    </schematicView>
    <pcbView>
     <p layer="copper0" svgId="connector4pad"/>
     <p layer="copper1" svgId="connector4pad"/>
    </pcbView>
   </views>
  </connector>
 </connectors>
 <buses>
  <bus id="v-">
   <nodeMember connectorId="connector1"/>
   <nodeMember connectorId="connector2"/>
  </bus>
  <bus id="v+">
   <nodeMember connectorId="connector3"/>
   <nodeMember connectorId="connector4"/>
  </bus>
 </buses>
 <url>https://www.adafruit.com/products/1862</url>
</module>
