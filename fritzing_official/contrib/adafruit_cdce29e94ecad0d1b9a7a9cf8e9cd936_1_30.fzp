<?xml version='1.0' encoding='UTF-8'?>
<module fritzingVersion="0.5.2b.02.18.4756" referenceFile="Adafruit Bi-Color 24-Bar Bargraph w I2C Backpack.fzp" moduleId="adafruit_cdce29e94ecad0d1b9a7a9cf8e9cd936_1_30">
 <version>4</version>
 <date>2016-08-17</date>
 <author>Adafruit</author>
 <description>&lt;!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0//EN" "http://www.w3.org/TR/REC-html40/strict.dtd">
&lt;html>&lt;head>&lt;meta name="qrichtext" content="1" />&lt;style type="text/css">
p, li { white-space: pre-wrap; }
&lt;/style>&lt;/head>&lt;body style=" font-family:'.SF NS Text'; font-size:13pt; font-weight:400; font-style:normal;">
&lt;p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">&lt;span style=" font-family:'Helvetica';">What's better than a single LED? Lots of LEDs! A fun way to make a small linear display is to use two 12-bar Bi-color bar-graphs. Much like our 8x8 and 7-segment backpacks, this backpack pairs perfectly with our bar-graphs and manages all the LED control and multiplexing.&lt;/span>&lt;/p>&lt;/body>&lt;/html></description>
 <title>Bi-Color 24-Bar Bargraph w I2C Backpack</title>
 <tags/>
 <properties>
  <property name="variant">variant 1</property>
  <property name="family">LED Backpack</property>
  <property name="part number">1721</property>
 </properties>
 <views>
  <breadboardView>
   <layers image="breadboard/adafruit_cdce29e94ecad0d1b9a7a9cf8e9cd936_1_breadboard_30.svg">
    <layer layerId="breadboard"/>
   </layers>
  </breadboardView>
  <schematicView>
   <layers image="schematic/adafruit_cdce29e94ecad0d1b9a7a9cf8e9cd936_1_schematic_30.svg">
    <layer layerId="schematic"/>
   </layers>
  </schematicView>
  <pcbView>
   <layers image="pcb/adafruit_cdce29e94ecad0d1b9a7a9cf8e9cd936_1_pcb_30.svg">
    <layer layerId="copper1"/>
    <layer layerId="silkscreen"/>
    <layer layerId="copper0"/>
   </layers>
  </pcbView>
  <iconView>
   <layers image="icon/adafruit_cdce29e94ecad0d1b9a7a9cf8e9cd936_1_icon_30.svg">
    <layer layerId="icon"/>
   </layers>
  </iconView>
 </views>
 <connectors>
  <connector type="male" name="VDD" id="connector10">
