<?xml version='1.0' encoding='UTF-8'?>
<module moduleId="adafruit_5ee35b060de3ea5b68d0a9a80ccde3bb_5_A4" referenceFile="Adafruit 16x8 LED Matrix Backpack.fzp" fritzingVersion="0.5.2b.02.18.4756">
 <version>4</version>
 <date>2016-08-22</date>
 <author>Adafruit</author>
 <description>&lt;!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0//EN" "http://www.w3.org/TR/REC-html40/strict.dtd">
&lt;html>&lt;head>&lt;meta name="qrichtext" content="1" />&lt;style type="text/css">
p, li { white-space: pre-wrap; }
&lt;/style>&lt;/head>&lt;body style=" font-family:'.SF NS Text'; font-size:13pt; font-weight:400; font-style:normal;">
&lt;p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">&lt;span style=" font-family:'Helvetica'; color:#454545;">This 16x8 monochrome LED matrix includes a driver chip for simple control via an I2C interface. The backpack features address-selection jumpers so you can connect up to eight matrices on a single I2C bus.&lt;/span>&lt;/p>&lt;/body>&lt;/html></description>
 <title>16x8 LED Matrix Backpack</title>
 <tags/>
 <properties>
  <property name="family">Adafruit 16x8 LED Matrix Backpack</property>
  <property name="part number">2052</property>
  <property name="variant">Orange</property>
 </properties>
 <views>
  <breadboardView>
   <layers image="breadboard/adafruit_5ee35b060de3ea5b68d0a9a80ccde3bb_5_breadboard_A4.svg">
    <layer layerId="breadboard"/>
   </layers>
  </breadboardView>
  <schematicView>
