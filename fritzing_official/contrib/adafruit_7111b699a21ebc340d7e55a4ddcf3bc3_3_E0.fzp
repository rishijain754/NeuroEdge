<?xml version='1.0' encoding='UTF-8'?>
<module referenceFile="Adafruit 14-segment LED Alphanumeric Backpack.fzp" fritzingVersion="0.5.2b.02.18.4756" moduleId="adafruit_7111b699a21ebc340d7e55a4ddcf3bc3_3_E0">
 <version>4</version>
 <date>2016-08-22</date>
 <author>Adafruit</author>
 <description>&lt;!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0//EN" "http://www.w3.org/TR/REC-html40/strict.dtd">
&lt;html>&lt;head>&lt;meta name="qrichtext" content="1" />&lt;style type="text/css">
p, li { white-space: pre-wrap; }
&lt;/style>&lt;/head>&lt;body style=" font-family:'.SF NS Text'; font-size:13pt; font-weight:400; font-style:normal;">
&lt;p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">&lt;span style=" font-family:'Helvetica'; color:#454545;">This is a nice, bright alphanumeric display that shows letters and numbers. It's super bright and designed for viewing from distances up to 23 feet (7 meters) away. Four digits with 14 segments on a black surface and we give you a set of two alphanumeric displays as well as a driver board so you can make a clock or a four letter word. Like our other LED backpacks, these are end-to-end stackable and by soldering the address jumpers on the back you can have up to 8 backpacks all sharing the same two I2C wires!&lt;/span>&lt;/p>&lt;/body>&lt;/html></description>
 <title>14-segment LED Alphanumeric Backpack</title>
