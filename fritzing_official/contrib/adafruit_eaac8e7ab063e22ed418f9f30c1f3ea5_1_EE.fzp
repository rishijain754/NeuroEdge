<?xml version='1.0' encoding='UTF-8'?>
<module fritzingVersion="0.5.2b.02.18.4756" moduleId="adafruit_eaac8e7ab063e22ed418f9f30c1f3ea5_1_EE" referenceFile="Adafruit Bicolor 8x8 LED Matrix Backpack.fzp">
 <version>4</version>
 <date>2016-08-20</date>
 <author>Adafruit</author>
 <description>&lt;!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0//EN" "http://www.w3.org/TR/REC-html40/strict.dtd">
&lt;html>&lt;head>&lt;meta name="qrichtext" content="1" />&lt;style type="text/css">
p, li { white-space: pre-wrap; }
&lt;/style>&lt;/head>&lt;body style=" font-family:'.SF NS Text'; font-size:13pt; font-weight:400; font-style:normal;">
&lt;p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;">&lt;span style=" font-family:'Helvetica'; color:#454545;">This 1.2&amp;quot; bi-color 8x8 LED matrix includes a driver chip for simple control via an I2C interface. It's called a Bicolor LED, but you can have 3 colors total by turning on the red and green LEDs, which creates yellow. That's 3 colors for the price of 2! The backpacks come with address-selection jumpers so you can connect up to eight bicolor matrices on a single I2C bus.&lt;/span>&lt;/p>&lt;/body>&lt;/html></description>
 <title>Bicolor 8x8 LED Matrix Backpack</title>
 <tags/>
 <properties>
  <property name="family">Adafruit LED Backpack</property>
  <property name="variant">Bicolor 8x8</property>
  <property name="part number">902</property>
 </properties>
 <views>
  <breadboardView>
   <layers image="breadboard/adafruit_eaac8e7ab063e22ed418f9f30c1f3ea5_1_breadboard_EE.svg">
