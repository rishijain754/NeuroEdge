  <connector name="TX" id="connector17" type="male">
   <description>TX</description>
   <views>
    <breadboardView>
     <p svgId="connector17pin" layer="breadboard"/>
    </breadboardView>
    <schematicView>
     <p terminalId="connector17terminal" svgId="connector17pin" layer="schematic"/>
    </schematicView>
