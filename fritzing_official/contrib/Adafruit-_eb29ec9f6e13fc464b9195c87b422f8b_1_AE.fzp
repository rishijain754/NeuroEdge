  <connector id="connector58" type="female" name="TX">
   <description>TX</description>
   <views>
    <breadboardView>
     <p layer="breadboard" svgId="connector58pin"/>
    </breadboardView>
    <schematicView>
     <p layer="schematic" terminalId="connector58terminal" svgId="connector58pin"/>
    </schematicView>
